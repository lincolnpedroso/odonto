<script>
var ANAM = [
  'Está em tratamento médico?','Diabetes?','Cirurgia recente?',
  'Alergia a medicamentos/anestesia?','Problema de pele/cicatrização?',
  'Depressão/pânico/ansiedade?','Doença infectocontagiosa?',
  'Histórico de convulsões/epilepsia?','Algum tipo de câncer?','Cardiopatia?',
  'Anemia?','Distúrbio circulatório?','Hipertensão?','Quelóide?',
  'Fez/faz uso de drogas?','Hipotensão?','Vitiligo?',
  'Está sob efeito de álcool?','Marcapasso?','Gestante?',
  'Dormiu a última noite?','Hemofilia?','Amamentando?',
  'Está em jejum?','Hepatite?'
];
var SUP = [18,17,16,15,14,13,12,11,21,22,23,24,25,26,27,28];
var INF = [48,47,46,45,44,43,42,41,31,32,33,34,35,36,37,38];

var S = {
  pacientes:[],consultas:[],transacoes:[],procedimentos:[],
  odontograma:{},anamData:{},
  curPacId:null,selDentes:[],tipoTrans:'entrada',
  calMes:new Date().getMonth(),calAno:new Date().getFullYear(),
  calView:'mes',calDia:new Date().toISOString().slice(0,10),
  editConsId:null
};

function genId(){ return Date.now().toString(36)+Math.random().toString(36).slice(2); }
function fmt(n){ return 'R$ '+Number(n||0).toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2}); }
function fmtDate(d){ if(!d)return'-'; var p=d.split('-'); return p[2]+'/'+p[1]+'/'+p[0]; }
function initials(n){ return n.split(' ').slice(0,2).map(function(w){return w[0];}).join('').toUpperCase(); }

function saveData(){
  try{ localStorage.setItem('odonto_v2', JSON.stringify(S)); }catch(e){ console.error(e); }
}

function loadData(){
  try{
    var raw = localStorage.getItem('odonto_v2');
    if(raw){
      var parsed = JSON.parse(raw);
      S.pacientes   = parsed.pacientes   || [];
      S.consultas   = parsed.consultas   || [];
      S.transacoes  = parsed.transacoes  || [];
      S.procedimentos = parsed.procedimentos || [];
      S.odontograma = parsed.odontograma || {};
      S.anamData    = parsed.anamData    || {};
    }
  }catch(e){ console.error(e); }
  if(!S.procedimentos.length){
    S.procedimentos = [
      {id:genId(),nome:'Consulta/Avaliação',categoria:'Geral',valor:150},
      {id:genId(),nome:'Limpeza (Profilaxia)',categoria:'Preventivo',valor:200},
      {id:genId(),nome:'Clareamento',categoria:'Estético',valor:800},
      {id:genId(),nome:'Restauração (resina)',categoria:'Restaurador',valor:250},
      {id:genId(),nome:'Extração simples',categoria:'Cirúrgico',valor:300},
      {id:genId(),nome:'Canal (tratamento)',categoria:'Endodontia',valor:900},
      {id:genId(),nome:'Coroa (porcelana)',categoria:'Prótese',valor:1800},
      {id:genId(),nome:'Implante',categoria:'Cirúrgico',valor:3500},
      {id:genId(),nome:'Ortodontia (mensal)',categoria:'Ortodontia',valor:350},
      {id:genId(),nome:'Aplicação de flúor',categoria:'Preventivo',valor:80}
    ];
  }
}

function showPage(page){
  document.querySelectorAll('section[data-page]').forEach(function(s){ s.classList.remove('active'); });
  document.querySelector('section[data-page="'+page+'"]').classList.add('active');
  var labels = {pacientes:'Pacientes',agenda:'Agenda',caixa:'Fluxo de Caixa',procedimentos:'Procedimentos'};
  document.getElementById('topbar-title').textContent = labels[page]||page;
  document.querySelectorAll('.nav-item').forEach(function(b){
    b.classList.toggle('active', b.textContent.trim()===labels[page]);
  });
  if(page==='pacientes'){ renderPacientes(); renderPacMetrics(); }
  if(page==='agenda'){ renderCal(); renderAgenda(); }
  if(page==='caixa'){ renderCaixa(); renderCaixaMetrics(); populateFiltroMes(); }
  if(page==='procedimentos'){ renderProcs(); }
}

function openModal(id){
  if(id==='modal-paciente') prepPaciente(null);
  if(id==='modal-consulta') prepConsulta(null);
  if(id==='modal-transacao') prepTransacao();
  if(id==='modal-backup') prepBackup();
  document.getElementById(id).style.display='flex';
}

function closeModal(id){
  document.getElementById(id).style.display='none';
}

function showTab(tabId, modalId){
  var modal = document.getElementById(modalId);
  modal.querySelectorAll('.tab-content').forEach(function(t){ t.classList.remove('active'); });
  modal.querySelectorAll('.tab-btn').forEach(function(b){ b.classList.remove('active'); });
  document.getElementById(tabId).classList.add('active');
  var order = ['tp-dados','tp-anamnese','tp-prontuario','tp-historico'];
  var idx = order.indexOf(tabId);
  var btns = modal.querySelectorAll('.tab-btn');
  if(btns[idx]) btns[idx].classList.add('active');
  if(tabId==='tp-historico' && S.curPacId) renderHistorico(S.curPacId);
}

/* ---- PACIENTES ---- */
function prepPaciente(id){
  S.curPacId = id;
  var p = id ? S.pacientes.find(function(x){return x.id===id;}) : null;
  document.getElementById('title-pac').textContent = p ? 'Editar Paciente' : 'Novo Paciente';
  var fields = ['nome','nasc','genero','cpf','rg','tel','email','end','bairro','cidade','cep','plano','carteirinha','obs','med','alergia','queixa','outro','sangue'];
  fields.forEach(function(f){
    var el = document.getElementById('p-'+f);
    if(el) el.value = p ? (p[f]||'') : '';
  });
  document.getElementById('p-resp-nome').value = p ? (p.respNome||'') : '';
  document.getElementById('p-resp-cpf').value  = p ? (p.respCpf||'') : '';
  document.getElementById('p-resp-cel').value  = p ? (p.respCel||'') : '';
  document.querySelectorAll('input[name="conheceu"]').forEach(function(r){ r.checked = p && p.conheceu===r.value; });
  S.odontograma = p && p.odontograma ? JSON.parse(JSON.stringify(p.odontograma)) : {};
  S.anamData    = p && p.anamData    ? JSON.parse(JSON.stringify(p.anamData))    : {};
  S.selDentes   = [];
  buildAnam();
  buildOdontograma();
  renderAtendimentos(id);
  showTab('tp-dados','modal-paciente');
}

function buildAnam(){
  var html = '<div class="anam-grid">';
  ANAM.forEach(function(q,i){
    var val = S.anamData[q] || 'N';
    html += '<div class="anam-item"><div class="anam-label">'+q+'</div><div class="anam-radio">';
    html += '<label><input type="radio" name="an'+i+'" value="S" '+(val==='S'?'checked':'')+' onchange="S.anamData[ANAM['+i+']]= \'S\'"> Sim</label>';
    html += '<label><input type="radio" name="an'+i+'" value="N" '+(val!=='S'?'checked':'')+' onchange="S.anamData[ANAM['+i+']]= \'N\'"> Não</label>';
    html += '</div></div>';
  });
  html += '</div>';
  document.getElementById('anam-table').innerHTML = html;
}

function salvarPaciente(){
  var nome = document.getElementById('p-nome').value.trim();
  if(!nome){ alert('Informe o nome do paciente.'); return; }
  var conheceu = '';
  var radio = document.querySelector('input[name="conheceu"]:checked');
  if(radio) conheceu = radio.value;
  var existing = S.curPacId ? S.pacientes.find(function(x){return x.id===S.curPacId;}) : null;
  var p = {
    id: S.curPacId || genId(),
    nome:nome,
    nasc:document.getElementById('p-nasc').value,
    genero:document.getElementById('p-genero').value,
    cpf:document.getElementById('p-cpf').value,
    rg:document.getElementById('p-rg').value,
    tel:document.getElementById('p-tel').value,
    email:document.getElementById('p-email').value,
    end:document.getElementById('p-end').value,
    bairro:document.getElementById('p-bairro').value,
    cidade:document.getElementById('p-cidade').value,
    cep:document.getElementById('p-cep').value,
    plano:document.getElementById('p-plano').value,
    carteirinha:document.getElementById('p-carteirinha').value,
    obs:document.getElementById('p-obs').value,
    med:document.getElementById('p-med').value,
    alergia:document.getElementById('p-alergia').value,
    queixa:document.getElementById('p-queixa').value,
    outro:document.getElementById('p-outro').value,
    sangue:document.getElementById('p-sangue').value,
    respNome:document.getElementById('p-resp-nome').value,
    respCpf:document.getElementById('p-resp-cpf').value,
    respCel:document.getElementById('p-resp-cel').value,
    conheceu:conheceu,
    odontograma:JSON.parse(JSON.stringify(S.odontograma)),
    anamData:JSON.parse(JSON.stringify(S.anamData)),
    atendimentos: existing ? (existing.atendimentos||[]) : []
  };
  if(S.curPacId){
    var idx = S.pacientes.findIndex(function(x){return x.id===S.curPacId;});
    S.pacientes[idx] = p;
  } else {
    S.pacientes.push(p);
  }
  saveData();
  closeModal('modal-paciente');
  renderPacientes();
  renderPacMetrics();
}

function renderPacientes(filter){
  filter = filter || '';
  var list = S.pacientes.filter(function(p){
    return p.nome.toLowerCase().includes(filter.toLowerCase()) ||
           (p.cpf||'').includes(filter) || (p.tel||'').includes(filter);
  });
  var tb = document.getElementById('tbody-pacientes');
  document.getElementById('empty-pac').style.display = list.length ? 'none' : 'block';
  var SB = {agendado:'b-blue',confirmado:'b-amber',realizado:'b-green',cancelado:'b-red',faltou:'b-gray',desmarcado:'b-red',remarcado:'b-purple'};
  var html = '';
  list.forEach(function(p){
    var ult = S.consultas.filter(function(c){return c.pacienteId===p.id&&c.status==='realizado';}).sort(function(a,b){return b.data>a.data?1:-1;})[0];
    var gBadge = {Masculino:'b-blue',Feminino:'b-pink','Não-binário':'b-purple','Prefiro não informar':'b-gray'}[p.genero]||'b-gray';
    html += '<tr><td><div class="patient-row"><div class="avatar">'+initials(p.nome)+'</div><div><div style="font-weight:500">'+p.nome+'</div><div style="font-size:11px;color:var(--text3)">'+(p.cpf||p.email||'')+'</div></div></div></td>';
    html += '<td>'+(p.tel||'-')+'</td>';
    html += '<td>'+(p.genero?'<span class="badge '+gBadge+'">'+p.genero+'</span>':'-')+'</td>';
    html += '<td><span class="badge b-gray">'+(p.plano||'Particular')+'</span></td>';
