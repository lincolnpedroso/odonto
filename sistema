    html+='<tr><td><div class="patient-row"><div class="avatar" style="width:28px;height:28px;font-size:11px">'+(p?initials(p.nome):'?')+'</div>'+(p?p.nome:'Removido')+'</div></td>';
    html+='<td>'+fmtDate(c.data)+' '+(c.hora||'')+'</td>';
    html+='<td>'+(c.proc||'-')+'</td>';
    html+='<td><span class="badge '+(STATUS_BADGE[c.status]||'b-gray')+'">'+c.status+'</span></td>';
    html+='<td><div style="display:flex;gap:6px"><button class="btn btn-sm" onclick="editCons(\''+c.id+'\')">Editar</button><button class="btn btn-sm btn-danger" onclick="delCons(\''+c.id+'\')">Remover</button></div></td></tr>';
  });
  tb.innerHTML=html;
}

function editCons(id){ prepConsulta(id); document.getElementById('modal-consulta').style.display='flex'; }
function delCons(id){ if(!confirm('Remover?'))return; S.consultas=S.consultas.filter(function(c){return c.id!==id;}); saveData(); renderCal(); renderAgenda(); }

/* ---- CAIXA ---- */
function prepTransacao(){
  setTipo('entrada');
  ['t-desc','t-valor','t-obs'].forEach(function(id){document.getElementById(id).value='';});
  document.getElementById('t-data').value=new Date().toISOString().slice(0,10);
  document.getElementById('t-cat').value='consulta';
  var sel=document.getElementById('t-pac');
  sel.innerHTML='<option value="">Nenhum</option>';
  S.pacientes.forEach(function(p){sel.innerHTML+='<option value="'+p.id+'">'+p.nome+'</option>';});
  populateFiltroMes();
}

function setTipo(t){
  S.tipoTrans=t;
  document.getElementById('btn-entrada').classList.toggle('active',t==='entrada');
  document.getElementById('btn-saida').classList.toggle('active',t==='saida');
}

function salvarTransacao(){
  var desc=document.getElementById('t-desc').value.trim();
  var val=parseFloat(document.getElementById('t-valor').value);
  if(!desc){alert('Informe a descrição.');return;}
  if(!val||val<=0){alert('Informe um valor válido.');return;}
  S.transacoes.push({id:genId(),desc:desc,valor:val,data:document.getElementById('t-data').value,tipo:S.tipoTrans,cat:document.getElementById('t-cat').value,pacienteId:document.getElementById('t-pac').value,obs:document.getElementById('t-obs').value});
  saveData(); closeModal('modal-transacao'); renderCaixa(); renderCaixaMetrics(); populateFiltroMes();
}

function populateFiltroMes(){
  var meses=[]; S.transacoes.forEach(function(t){var m=t.data.slice(0,7); if(meses.indexOf(m)===-1)meses.push(m);}); meses.sort().reverse();
  var sel=document.getElementById('filtro-mes'); if(!sel)return;
  var cur=sel.value;
  sel.innerHTML='<option value="">Todos os meses</option>';
  meses.forEach(function(m){var p=m.split('-'); sel.innerHTML+='<option value="'+m+'"'+(cur===m?' selected':'')+'>'+new Date(p[0],p[1]-1).toLocaleDateString('pt-BR',{month:'long',year:'numeric'})+'</option>';});
}

function renderCaixa(){
  var mes=document.getElementById('filtro-mes')?document.getElementById('filtro-mes').value:'';
  var tipo=document.getElementById('filtro-tipo')?document.getElementById('filtro-tipo').value:'';
  var lista=S.transacoes.filter(function(t){return(!mes||t.data.startsWith(mes))&&(!tipo||t.tipo===tipo);}).sort(function(a,b){return b.data>a.data?1:-1;});
  var tb=document.getElementById('tbody-caixa');
  document.getElementById('empty-caixa').style.display=lista.length?'none':'block';
  var cat={consulta:'Consulta',procedimento:'Procedimento',material:'Material',equip:'Equipamento',aluguel:'Aluguel',salario:'Salário',outros:'Outros'};
  var html='';
  lista.forEach(function(t){
    var p=t.pacienteId?S.pacientes.find(function(x){return x.id===t.pacienteId;}):null;
    html+='<tr><td>'+fmtDate(t.data)+'</td><td>'+t.desc+(p?' <span style="font-size:11px;color:var(--text3)">· '+p.nome+'</span>':'')+'</td>';
    html+='<td><span class="badge b-gray">'+(cat[t.cat]||t.cat)+'</span></td>';
    html+='<td><span class="badge '+(t.tipo==='entrada'?'b-green':'b-red')+'">'+(t.tipo==='entrada'?'Entrada':'Saída')+'</span></td>';
    html+='<td style="text-align:right;font-weight:600;color:'+(t.tipo==='entrada'?'var(--green)':'var(--red)')+'">'+fmt(t.valor)+'</td>';
    html+='<td><button class="btn btn-sm btn-danger" onclick="delTrans(\''+t.id+'\')">Remover</button></td></tr>';
  });
  tb.innerHTML=html;
}

function renderCaixaMetrics(){
  var mes=new Date().toISOString().slice(0,7);
  var mt=S.transacoes.filter(function(t){return t.data.startsWith(mes);});
  var ent=mt.filter(function(t){return t.tipo==='entrada';}).reduce(function(s,t){return s+t.valor;},0);
  var sai=mt.filter(function(t){return t.tipo==='saida';}).reduce(function(s,t){return s+t.valor;},0);
  var saldo=ent-sai;
  document.getElementById('metrics-caixa').innerHTML=
    '<div class="metric-card"><div class="metric-icon" style="background:var(--green)"><svg viewBox="0 0 24 24"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 100 7h5a3.5 3.5 0 110 7H6"/></svg></div><div class="metric-label">Entradas (mês)</div><div class="metric-value" style="color:var(--green)">'+fmt(ent)+'</div></div>'+
    '<div class="metric-card"><div class="metric-icon" style="background:var(--red)"><svg viewBox="0 0 24 24"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 100 7h5a3.5 3.5 0 110 7H6"/></svg></div><div class="metric-label">Saídas (mês)</div><div class="metric-value" style="color:var(--red)">'+fmt(sai)+'</div></div>'+
    '<div class="metric-card"><div class="metric-icon" style="background:'+(saldo>=0?'var(--primary)':'var(--red)')+'"><svg viewBox="0 0 24 24"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/></svg></div><div class="metric-label">Saldo do mês</div><div class="metric-value" style="color:'+(saldo>=0?'var(--primary)':'var(--red)')+'">'+fmt(Math.abs(saldo))+'</div></div>'+
    '<div class="metric-card"><div class="metric-icon" style="background:var(--amber)"><svg viewBox="0 0 24 24"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg></div><div class="metric-label">Lançamentos (mês)</div><div class="metric-value">'+mt.length+'</div></div>';
}

function delTrans(id){ if(!confirm('Remover?'))return; S.transacoes=S.transacoes.filter(function(t){return t.id!==id;}); saveData(); renderCaixa(); renderCaixaMetrics(); }

/* ---- PROCEDIMENTOS ---- */
function renderProcs(){
  var html='';
  S.procedimentos.forEach(function(p){
    html+='<tr><td><input type="text" value="'+p.nome+'" onchange="updProc(\''+p.id+'\',\'nome\',this.value)"></td>';
    html+='<td><input type="text" value="'+p.categoria+'" onchange="updProc(\''+p.id+'\',\'categoria\',this.value)"></td>';
    html+='<td><input type="number" value="'+p.valor+'" step="0.01" onchange="updProc(\''+p.id+'\',\'valor\',parseFloat(this.value))" style="text-align:right"></td>';
    html+='<td><button class="btn btn-sm btn-danger" onclick="delProc(\''+p.id+'\')">Remover</button></td></tr>';
  });
  document.getElementById('tbody-procs').innerHTML=html;
}

function updProc(id,f,v){ var p=S.procedimentos.find(function(x){return x.id===id;}); if(p){p[f]=v;saveData();} }
function addProc(){ S.procedimentos.push({id:genId(),nome:'Novo procedimento',categoria:'Geral',valor:0}); saveData(); renderProcs(); }
function delProc(id){ if(!confirm('Remover?'))return; S.procedimentos=S.procedimentos.filter(function(p){return p.id!==id;}); saveData(); renderProcs(); }



/* ---- INIT ---- */
document.getElementById('topbar-date').textContent = new Date().toLocaleDateString('pt-BR',{weekday:'short',day:'2-digit',month:'short',year:'numeric'});
loadData();
renderPacientes();
renderPacMetrics();
populateFiltroMes();
</script>
