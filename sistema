  });
  tb.innerHTML = html;
}

function editPaciente(id){ prepPaciente(id); document.getElementById('modal-paciente').style.display='flex'; }
function delPaciente(id){
  if(!confirm('Remover este paciente?')) return;
  S.pacientes = S.pacientes.filter(function(p){return p.id!==id;});
  saveData(); renderPacientes(); renderPacMetrics();
}

function renderPacMetrics(){
  var mes = new Date().toISOString().slice(0,7);
  document.getElementById('m-total').textContent = S.pacientes.length;
  document.getElementById('m-cons').textContent  = S.consultas.filter(function(c){return c.data.startsWith(mes)&&c.status==='realizado';}).length;
  document.getElementById('m-pend').textContent  = S.consultas.filter(function(c){return c.data>=new Date().toISOString().slice(0,10)&&(c.status==='agendado'||c.status==='confirmado');}).length;
  var rec = S.transacoes.filter(function(t){return t.data.startsWith(mes)&&t.tipo==='entrada';}).reduce(function(s,t){return s+t.valor;},0);
  document.getElementById('m-rec').textContent = fmt(rec);
}

/* ---- ODONTOGRAMA ---- */
function buildOdontograma(){
  var c = document.getElementById('odontograma');
  function makeRow(arr){
    var d = document.createElement('div'); d.className='odonto-row';
    arr.forEach(function(num){
      var el = document.createElement('div');
      el.className = 'dente '+(S.odontograma[num]||'');
      el.dataset.num = num;
      el.innerHTML = '<span style="font-size:9px;pointer-events:none">'+num+'</span>';
      el.onclick = function(){
        var i = S.selDentes.indexOf(num);
        if(i===-1){ S.selDentes.push(num); el.classList.add('selected'); }
        else{ S.selDentes.splice(i,1); el.classList.remove('selected'); }
      };
      d.appendChild(el);
    });
    return d;
  }
  c.innerHTML = '';
  c.appendChild(makeRow(SUP));
  var sep = document.createElement('div'); sep.className='odonto-sep'; sep.textContent='Superior / Inferior';
  c.appendChild(sep);
  c.appendChild(makeRow(INF));
}

function marcarDente(status){
  S.selDentes.forEach(function(num){
    S.odontograma[num] = status;
    var el = document.querySelector('.dente[data-num="'+num+'"]');
    if(el){ el.className='dente '+status+' selected'; }
  });
}

/* ---- PRONTUARIO ---- */
function renderAtendimentos(pacId){
  var el = document.getElementById('lista-at');
  var p = pacId ? S.pacientes.find(function(x){return x.id===pacId;}) : null;
  var ats = p ? (p.atendimentos||[]) : [];
  if(!ats.length){ el.innerHTML='<p style="font-size:13px;color:var(--text3);padding:10px 0">Nenhum atendimento.</p>'; return; }
  var html = '';
  ats.slice().sort(function(a,b){return b.data>a.data?1:-1;}).forEach(function(a){
    html += '<div class="hist-card"><div class="hist-top"><span class="hist-proc">'+(a.proc||'Atendimento')+(a.dente?' — Dente(s): '+a.dente:'')+'</span><span class="hist-val">'+fmt(a.valor||0)+'</span></div><div class="hist-meta">'+fmtDate(a.data)+(a.obs?' · '+a.obs:'')+'</div></div>';
  });
  el.innerHTML = html;
}

function addAtendimento(){
  var f = document.getElementById('form-at'); f.style.display='block';
  var sel = document.getElementById('at-proc');
  sel.innerHTML = '<option value="">Selecionar...</option>';
  S.procedimentos.forEach(function(p){ sel.innerHTML += '<option value="'+p.nome+'">'+p.nome+' — '+fmt(p.valor)+'</option>'; });
  document.getElementById('at-data').value = new Date().toISOString().slice(0,10);
  sel.onchange = function(){
    var proc = S.procedimentos.find(function(p){return p.nome===sel.value;});
    if(proc) document.getElementById('at-valor').value = proc.valor;
  };
}

function salvarAtendimento(){
  if(!S.curPacId) return;
  var p = S.pacientes.find(function(x){return x.id===S.curPacId;});
  if(!p) return;
  if(!p.atendimentos) p.atendimentos = [];
  var at = {
    id:genId(),
    data:document.getElementById('at-data').value,
    proc:document.getElementById('at-proc').value,
    valor:parseFloat(document.getElementById('at-valor').value)||0,
    dente:document.getElementById('at-dente').value,
    obs:document.getElementById('at-obs').value
  };
  p.atendimentos.push(at);
  if(at.valor>0){
    S.transacoes.push({id:genId(),desc:(at.proc||'Atendimento')+' — '+p.nome,valor:at.valor,data:at.data,tipo:'entrada',cat:'procedimento',pacienteId:p.id,obs:''});
  }
  saveData();
  document.getElementById('form-at').style.display='none';
  renderAtendimentos(S.curPacId);
}

/* ---- HISTORICO ---- */
function renderHistorico(pacId){
  var p = S.pacientes.find(function(x){return x.id===pacId;});
  if(!p){ document.getElementById('hist-content').innerHTML=''; return; }
  var consultas = S.consultas.filter(function(c){return c.pacienteId===pacId;}).sort(function(a,b){return b.data>a.data?1:-1;});
  var pagamentos = S.transacoes.filter(function(t){return t.pacienteId===pacId;}).sort(function(a,b){return b.data>a.data?1:-1;});
  var totalPago = pagamentos.filter(function(t){return t.tipo==='entrada';}).reduce(function(s,t){return s+t.valor;},0);
  var SB = {agendado:'b-blue',confirmado:'b-amber',realizado:'b-green',cancelado:'b-red',faltou:'b-gray',desmarcado:'b-red',remarcado:'b-purple'};
  var html = '<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:20px">';
  html += '<div class="metric-card" style="padding:14px"><div class="metric-label">Total consultas</div><div class="metric-value" style="font-size:18px">'+consultas.length+'</div></div>';
  html += '<div class="metric-card" style="padding:14px"><div class="metric-label">Realizadas</div><div class="metric-value" style="font-size:18px;color:var(--green)">'+consultas.filter(function(c){return c.status==='realizado';}).length+'</div></div>';
  html += '<div class="metric-card" style="padding:14px"><div class="metric-label">Total pago</div><div class="metric-value" style="font-size:18px;color:var(--primary)">'+fmt(totalPago)+'</div></div>';
  html += '</div><div style="font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px">Dados pessoais</div>';
  var infos = [['Telefone',p.tel],['E-mail',p.email],['CPF',p.cpf],['Data de nasc.',fmtDate(p.nasc)],['Gênero',p.genero],['Plano',p.plano||'Particular'],['Cidade',p.cidade],['Como conheceu',p.conheceu]];
  html += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:4px 20px;margin-bottom:16px;font-size:13px">';
  infos.forEach(function(item){ if(item[1]) html += '<div style="padding:6px 0;border-bottom:1px solid var(--border)"><span style="color:var(--text3);font-size:12px">'+item[0]+': </span><strong>'+item[1]+'</strong></div>'; });
  if(p.respNome) html += '<div style="grid-column:1/-1;padding:6px 0;border-bottom:1px solid var(--border)"><span style="color:var(--text3);font-size:12px">Responsável: </span><strong>'+p.respNome+(p.respCpf?' · CPF: '+p.respCpf:'')+(p.respCel?' · '+p.respCel:'')+'</strong></div>';
  html += '</div><div style="font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px">Histórico de consultas</div>';
  if(consultas.length){
    consultas.forEach(function(c){
      html += '<div class="hist-card"><div class="hist-top"><span class="hist-proc">'+(c.proc||'Consulta')+'</span><span class="badge '+(SB[c.status]||'b-gray')+'">'+c.status+'</span></div><div class="hist-meta">'+fmtDate(c.data)+' às '+(c.hora||'')+(c.obs?' · '+c.obs:'')+'</div></div>';
    });
  } else { html += '<p style="font-size:13px;color:var(--text3);margin-bottom:16px">Nenhuma consulta.</p>'; }
  html += '<div style="font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;margin:14px 0 10px">Histórico de pagamentos</div>';
  if(pagamentos.length){
    html += '<table><thead><tr><th>Data</th><th>Descrição</th><th>Tipo</th><th style="text-align:right">Valor</th></tr></thead><tbody>';
    pagamentos.forEach(function(t){
      html += '<tr><td>'+fmtDate(t.data)+'</td><td>'+t.desc+'</td><td><span class="badge '+(t.tipo==='entrada'?'b-green':'b-red')+'">'+(t.tipo==='entrada'?'Entrada':'Saída')+'</span></td><td style="text-align:right;font-weight:600;color:'+(t.tipo==='entrada'?'var(--green)':'var(--red)')+'">'+fmt(t.valor)+'</td></tr>';
    });
    html += '</tbody></table>';
  } else { html += '<p style="font-size:13px;color:var(--text3)">Nenhum pagamento.</p>'; }
  document.getElementById('hist-content').innerHTML = html;
}

/* ---- AGENDA ---- */
var STATUS_BADGE = {agendado:'b-blue',confirmado:'b-amber',realizado:'b-green',cancelado:'b-red',faltou:'b-gray',desmarcado:'b-red',remarcado:'b-purple'};
var HORAS = ['07:00','08:00','09:00','10:00','11:00','12:00','13:00','14:00','15:00','16:00','17:00','18:00','19:00','20:00'];

function prepConsulta(id){
  S.editConsId = id;
  var c = id ? S.consultas.find(function(x){return x.id===id;}) : null;
  document.getElementById('title-cons').textContent = c ? 'Editar Consulta' : 'Nova Consulta';
  var selP = document.getElementById('c-pac');
  selP.innerHTML = '<option value="">Selecionar...</option>';
  S.pacientes.forEach(function(p){ selP.innerHTML += '<option value="'+p.id+'"'+(c&&c.pacienteId===p.id?' selected':'')+'>'+p.nome+'</option>'; });
  var selPr = document.getElementById('c-proc');
  selPr.innerHTML = '<option value="">Selecionar...</option>';
  S.procedimentos.forEach(function(p){ selPr.innerHTML += '<option value="'+p.nome+'"'+(c&&c.proc===p.nome?' selected':'')+'>'+p.nome+'</option>'; });
  document.getElementById('c-data').value   = c ? c.data   : new Date().toISOString().slice(0,10);
  document.getElementById('c-hora').value   = c ? c.hora   : '09:00';
  document.getElementById('c-status').value = c ? c.status : 'agendado';
  document.getElementById('c-dur').value    = c ? c.duracao: '60';
  document.getElementById('c-obs').value    = c ? c.obs    : '';
}

function salvarConsulta(){
  var pid = document.getElementById('c-pac').value;
  if(!pid){ alert('Selecione um paciente.'); return; }
  var data = document.getElementById('c-data').value;
  if(!data){ alert('Informe a data.'); return; }
  var c = {
    id: S.editConsId || genId(),
    pacienteId:pid,
    proc:document.getElementById('c-proc').value,
    data:data,
    hora:document.getElementById('c-hora').value,
    status:document.getElementById('c-status').value,
    duracao:document.getElementById('c-dur').value,
    obs:document.getElementById('c-obs').value
  };
  if(S.editConsId){
    var idx = S.consultas.findIndex(function(x){return x.id===S.editConsId;});
    S.consultas[idx] = c;
  } else {
    S.consultas.push(c);
  }
  saveData();
  closeModal('modal-consulta');
  renderCal(); renderAgenda();
}

function setView(v){
  S.calView = v;
  document.querySelectorAll('.view-btn').forEach(function(b){
    b.classList.toggle('active', b.textContent.trim()==={mes:'Mês',semana:'Semana',dia:'Dia'}[v]);
  });
  document.getElementById('view-mes').style.display     = v==='mes'    ?'block':'none';
  document.getElementById('view-semana').style.display  = v==='semana' ?'block':'none';
  document.getElementById('view-dia').style.display     = v==='dia'    ?'block':'none';
  renderCal();
}

function navCal(d){
  if(S.calView==='mes'){ S.calMes+=d; if(S.calMes>11){S.calMes=0;S.calAno++;} if(S.calMes<0){S.calMes=11;S.calAno--;} }
  else { var dt=new Date(S.calDia); dt.setDate(dt.getDate()+(S.calView==='semana'?d*7:d)); S.calDia=dt.toISOString().slice(0,10); }
  renderCal();
}

function goToday(){ var n=new Date(); S.calMes=n.getMonth(); S.calAno=n.getFullYear(); S.calDia=n.toISOString().slice(0,10); renderCal(); }

function renderCal(){
  if(S.calView==='mes') renderMes();
  else if(S.calView==='semana') renderSemana();
  else renderDia();
}

function evtClass(status){ return status||''; }

function renderMes(){
  var label = document.getElementById('cal-label');
  var hoje  = new Date().toISOString().slice(0,10);
  var dias  = ['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];
  label.textContent = new Date(S.calAno,S.calMes,1).toLocaleDateString('pt-BR',{month:'long',year:'numeric'});
  document.getElementById('cal-hdr').innerHTML = dias.map(function(d){return '<div class="cal-hdr">'+d+'</div>';}).join('');
  var primeiro = new Date(S.calAno,S.calMes,1);
  var ultimo   = new Date(S.calAno,S.calMes+1,0);
  var html = '';
  for(var i=0;i<primeiro.getDay();i++){
    var dd=new Date(S.calAno,S.calMes,1-primeiro.getDay()+i);
    html+='<div class="cal-day other-month"><div class="cal-day-n">'+dd.getDate()+'</div></div>';
  }
  for(var d=1;d<=ultimo.getDate();d++){
    var ds=S.calAno+'-'+String(S.calMes+1).padStart(2,'0')+'-'+String(d).padStart(2,'0');
    var cons=S.consultas.filter(function(c){return c.data===ds;});
    html+='<div class="cal-day'+(ds===hoje?' today':'')+'" onclick="abrirDia(\''+ds+'\')">';
    html+='<div class="cal-day-n">'+d+'</div>';
    cons.slice(0,2).forEach(function(c){
      var p=S.pacientes.find(function(x){return x.id===c.pacienteId;});
      html+='<div class="cal-evt '+evtClass(c.status)+'">'+(c.hora||'')+' '+(p?p.nome.split(' ')[0]:'')+'</div>';
    });
    if(cons.length>2) html+='<div style="font-size:10px;color:var(--text3)">+'+( cons.length-2)+' mais</div>';
    html+='</div>';
  }
  var resto=(7-((primeiro.getDay()+ultimo.getDate())%7))%7;
  for(var j=1;j<=resto&&resto<7;j++) html+='<div class="cal-day other-month"><div class="cal-day-n">'+j+'</div></div>';
  document.getElementById('cal-cells').innerHTML=html;
}

function renderSemana(){
  var base=new Date(S.calDia); var dow=base.getDay();
  var lun=new Date(base); lun.setDate(base.getDate()-dow);
  document.getElementById('cal-label').textContent='Semana de '+lun.toLocaleDateString('pt-BR',{day:'2-digit',month:'short'});
  var dias=['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];
  var hoje=new Date().toISOString().slice(0,10);
  var html='<div class="week-hdr" style="background:var(--surface2)"></div>';
  for(var i=0;i<7;i++){
    var dd=new Date(lun); dd.setDate(lun.getDate()+i);
    var ds=dd.toISOString().slice(0,10);
    html+='<div class="week-hdr'+(ds===hoje?' today':'')+'">'+dias[i]+'<br><span style="font-size:13px;font-weight:600;color:'+(ds===hoje?'var(--primary)':'var(--text)')+'">'+dd.getDate()+'</span></div>';
  }
  HORAS.forEach(function(h){
    html+='<div class="week-time">'+h+'</div>';
    for(var i=0;i<7;i++){
      var dd2=new Date(lun); dd2.setDate(lun.getDate()+i);
      var ds2=dd2.toISOString().slice(0,10);
      var cons=S.consultas.filter(function(c){return c.data===ds2&&c.hora&&c.hora.startsWith(h.slice(0,2));});
      html+='<div class="week-cell" onclick="abrirDia(\''+ds2+'\',\''+h+'\')">';
      cons.forEach(function(c){ var p=S.pacientes.find(function(x){return x.id===c.pacienteId;}); html+='<div class="cal-evt '+evtClass(c.status)+'">'+(p?p.nome.split(' ')[0]:'')+'</div>'; });
      html+='</div>';
    }
  });
  document.getElementById('week-grid').innerHTML=html;
  document.getElementById('week-grid').style.gridTemplateColumns='60px repeat(7,1fr)';
}

function renderDia(){
  var d=new Date(S.calDia);
  document.getElementById('cal-label').textContent=d.toLocaleDateString('pt-BR',{weekday:'long',day:'2-digit',month:'long',year:'numeric'});
  var html='';
  HORAS.forEach(function(h){
    var cons=S.consultas.filter(function(c){return c.data===S.calDia&&c.hora&&c.hora.startsWith(h.slice(0,2));});
    html+='<div class="day-time">'+h+'</div><div class="day-cell" onclick="abrirDia(\''+S.calDia+'\',\''+h+'\')">';
    cons.forEach(function(c){ var p=S.pacientes.find(function(x){return x.id===c.pacienteId;}); html+='<span class="cal-evt '+evtClass(c.status)+'" style="display:inline-flex;margin-right:4px">'+(p?p.nome:'')+(c.proc?' — '+c.proc:'')+'</span>'; });
    html+='</div>';
  });
  document.getElementById('day-grid').innerHTML=html;
}

function abrirDia(data,hora){
  prepConsulta(null);
  document.getElementById('c-data').value=data;
  if(hora) document.getElementById('c-hora').value=hora;
  document.getElementById('modal-consulta').style.display='flex';
